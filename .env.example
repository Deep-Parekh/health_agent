# LLM backend — auto-detected from whichever key is set (openai > groq > ollama),
# or forced with AGENT_BACKEND. Deployment uses OPENAI_API_KEY (Space secret).
OPENAI_API_KEY=your_openai_key_here
# GROQ_API_KEY=your_groq_key_here
# AGENT_BACKEND=openai
# AGENT_MODEL_ID=gpt-4o-mini

# Per-user memory: Supabase Postgres connection string.
# Supabase dashboard -> Project Settings -> Database -> Connection string (URI).
# Unset -> falls back to local SQLite at data/users.db (fine for dev,
# ephemeral on HF Spaces).
# DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-us-west-1.pooler.supabase.com:5432/postgres
